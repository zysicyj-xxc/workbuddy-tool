# 复制为 .env 后按需修改。切勿把含真实密码的 .env 提交到 Git。
#
# docker-compose 内 MySQL 用户固定为 workbuddy / workbuddy_pass（见 docker-compose.yml），
# 避免宿主机 MYSQL_USER 环境变量干扰初始化。

# 应用端口
APP_PORT=8000
PROXY_PORT=8002
MYSQL_PORT=3306

# 数据包导入导出口令（跨环境必须一致；开源前务必修改）
DATA_PACKAGE_PASSWORD=workbuddy-change-me

# 可选：HTTP Basic Auth（留空则关闭，便于本地）
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=

# 可选：出站代理 / TLS
HTTP_SSL_VERIFY=true
OUTBOUND_PROXY=
